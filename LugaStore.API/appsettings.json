{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Postgres": "",
    "RabbitMq": "localhost"
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "LugaStore",
    "Audience": "LugaStoreUsers",
    "ExpiryInMinutes": 15,
    "RefreshTokenExpiryInDays": 7
  },
  "RefreshTokenPaths": {
    "CustomerRefreshPath": "/customer/auth/refresh-token",
    "AdminRefreshPath": "/admin/auth/refresh-token",
    "PartnerRefreshPath": "/partner/auth/refresh-token",
    "PartnerManagerRefreshPath": "/partner/manager/auth/refresh-token"
  },
  "App": {
    "FrontendUrl": "https://luga-store.com",
    "Cors": {
      "AllowedOrigins": [
        "http://localhost:3000"
      ]
    }
  },
  "Openinary": {
    "BaseUrl": "http://localhost:3000",
    "ApiKey": ""
  },
  "Email": {
    "Host": "smtp.example.com",
    "Port": 587,
    "Username": "your-username",
    "Password": "your-password",
    "FromName": "Luga Store",
    "FromEmail": "noreply@lugastore.com",
    "UseSsl": false
  },
  "RateLimit": {
    "RejectionStatusCode": 429,
    "Policies": {
      "Global": {
        "Window": "00:01:00",
        "PermitLimit": 100,
        "QueueLimit": 0,
        "QueueProcessingOrder": "OldestFirst"
      },
      "Auth": {
        "Window": "00:01:00",
        "PermitLimit": 10,
        "QueueLimit": 0,
        "QueueProcessingOrder": "OldestFirst"
      }
    }
  }
}