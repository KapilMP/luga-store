{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Postgres": ""
  },
  "Jwt": {
    "Secret": "",
    "Issuer": "LugaStore",
    "Audience": "LugaStoreUsers",
    "ExpiryInMinutes": 15,
    "RefreshTokenExpiryInDays": 7
  },
  "RefreshTokenPaths": {
    "CustomerRefreshPath": "/customer/auth/refresh-token",
    "AdminRefreshPath": "/admin/auth/refresh-token",
    "PartnerRefreshPath": "/partner/auth/refresh-token",
    "PartnerManagerRefreshPath": "/partner/manager/auth/refresh-token"
  },
  "App": {
    "FrontendUrl": "https://luga-store.com",
    "Cors": {
      "AllowedOrigins": [
        "http://localhost:3000"
      ]
    }
  },
  "Openinary": {
    "BaseUrl": "http://localhost:3000",
    "ApiKey": ""
  },
  "Email": {
    "FromName": "Luga Store",
    "FromEmail": "onboarding@resend.dev"
  },
  "Resend": {
    "ApiToken": ""
  },
  "S3": {
    "BucketName": "YOUR_BUCKET_NAME",
    "AccessKey": "YOUR_ACCESS_KEY",
    "SecretKey": "YOUR_SECRET_KEY",
    "Region": "us-east-1",
    "Endpoint": ""
  },
  "RateLimiting": {
    "RejectionStatusCode": 429,
    "Policies": {
      "Global": {
        "Window": "00:01:00",
        "PermitLimit": 200,
        "QueueLimit": 0,
        "QueueProcessingOrder": "OldestFirst",
        "Partition": "Global"
      },
      "Auth": {
        "Window": "00:01:00",
        "PermitLimit": 5,
        "QueueLimit": 0,
        "QueueProcessingOrder": "OldestFirst",
        "Partition": "IP"
      },
      "ProductBrowsing": {
        "Window": "00:01:00",
        "PermitLimit": 120,
        "QueueLimit": 0,
        "QueueProcessingOrder": "OldestFirst",
        "Partition": "IP"
      },
      "Search": {
        "Window": "00:01:00",
        "PermitLimit": 60,
        "QueueLimit": 0,
        "QueueProcessingOrder": "OldestFirst",
        "Partition": "IP"
      },
      "Cart": {
        "Window": "00:00:10",
        "PermitLimit": 20,
        "QueueLimit": 0,
        "QueueProcessingOrder": "OldestFirst",
        "Partition": "User"
      },
      "Checkout": {
        "Window": "00:01:00",
        "PermitLimit": 5,
        "QueueLimit": 0,
        "QueueProcessingOrder": "OldestFirst",
        "Partition": "User"
      },
      "Payment": {
        "Window": "00:01:00",
        "PermitLimit": 3,
        "QueueLimit": 0,
        "QueueProcessingOrder": "OldestFirst",
        "Partition": "User"
      },
      "AccountActions": {
        "Window": "00:01:00",
        "PermitLimit": 10,
        "QueueLimit": 0,
        "QueueProcessingOrder": "OldestFirst",
        "Partition": "User"
      },
      "FileUpload": {
        "Window": "00:01:00",
        "PermitLimit": 5,
        "QueueLimit": 0,
        "QueueProcessingOrder": "OldestFirst",
        "Partition": "User"
      }
    }
  },
  "Google": {
    "ClientId": "YOUR_GOOGLE_CLIENT_ID",
    "ClientSecret": "YOUR_GOOGLE_CLIENT_SECRET"
  }
}