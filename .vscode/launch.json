{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch WebAPI",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "dotnet: build",
      "program": "${workspaceFolder}/WebAPI/bin/Debug/net10.0/LugaStore.WebAPI.dll",
      "args": [],
      "cwd": "${workspaceFolder}/WebAPI",
      "stopAtEntry": false,
      "justMyCode": true,
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "sourceFileMap": {
        "/Views": "${workspaceFolder}"
      }
    }
  ]
}
